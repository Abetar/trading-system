generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AssetType {
  ETF
  STOCK
}

enum SignalAction {
  BUY
  SELL
  HOLD
  NO_TRADE
}

enum OrderSide {
  BUY
  SELL
}

model Asset {
  id        String    @id @default(cuid())
  symbol    String    @unique
  name      String
  type      AssetType
  currency  String
  isActive  Boolean   @default(true)

  // Relaciones
  priceSnapshots PriceSnapshot[]
  signals        Signal[]
  trades         Trade[]
  position       Position?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriceSnapshot {
  id        String   @id @default(cuid())

  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  date      DateTime
  close     Decimal  @db.Decimal(18, 6)

  createdAt DateTime @default(now())

  @@unique([assetId, date])
  @@index([date])
  @@index([assetId])
}

model Signal {
  id        String       @id @default(cuid())

  assetId   String
  asset     Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  date      DateTime
  action    SignalAction

  priceReference Decimal @db.Decimal(18, 6)

  note      String?
  executed  Boolean @default(false)

  // 🔥 RELACIÓN INVERSA (FIX)
  trades    Trade[]

  createdAt DateTime @default(now())

  @@index([date])
  @@index([assetId, date])
}

model Trade {
  id        String    @id @default(cuid())

  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)

  side      OrderSide

  price     Decimal   @db.Decimal(18, 6)
  quantity  Decimal   @db.Decimal(18, 6)

  executedAt DateTime @default(now())

  // 🔥 relación opcional con señal
  signalId  String?
  signal    Signal?   @relation(fields: [signalId], references: [id])

  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([executedAt])
}

model Position {
  id        String    @id @default(cuid())

  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  quantity  Decimal   @db.Decimal(18, 6)
  avgPrice  Decimal   @db.Decimal(18, 6)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assetId])
}

model PortfolioMetric {
  id        String   @id @default(cuid())

  date      DateTime @unique

  totalPnl        Decimal @db.Decimal(18, 6)
  totalPnlPct     Decimal @db.Decimal(10, 4)

  winRate         Decimal? @db.Decimal(10, 4)
  totalTrades     Int?

  createdAt DateTime @default(now())
}